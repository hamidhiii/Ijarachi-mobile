# Rentoo — пример переменных окружения.
# Скопируй в `.env`, заполни реальные значения.

# Базовый URL API. Оставь пустым для дефолта.
EXPO_PUBLIC_API_URL=https://api.rentoo.uz/api/v1

# Мок-режим: true — все сервисы возвращают моки,
# false — делают реальные HTTP-запросы через api/client.ts.
EXPO_PUBLIC_MOCK_MODE=true
