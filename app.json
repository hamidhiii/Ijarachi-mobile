{
  "expo": {
    "name": "Rentoo",
    "slug": "rentoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rentoo",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "owner": "zinvo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zinvo.rentoo",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Rentoo использует камеру, чтобы вы могли сфотографировать вещь для объявления и зафиксировать состояние при выдаче/возврате.",
        "NSPhotoLibraryUsageDescription": "Rentoo запрашивает доступ к галерее, чтобы прикрепить фото вещи к объявлению.",
        "NSPhotoLibraryAddUsageDescription": "Rentoo сохраняет подтверждающие фото в галерею по вашему запросу.",
        "NSLocationWhenInUseUsageDescription": "Rentoo показывает ваше местоположение арендодателю/арендатору для подтверждения передачи вещи."
      }
    },
    "android": {
      "package": "com.zinvo.rentoo",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a7ea4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#0a0a0a"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Rentoo запрашивает доступ к галерее, чтобы прикрепить фото вещи к объявлению.",
          "cameraPermission": "Rentoo использует камеру, чтобы вы могли сфотографировать вещь для объявления."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
